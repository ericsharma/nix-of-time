{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "PM2.5",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "µg/m³",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 12 },
              { "color": "orange", "value": 35 },
              { "color": "red", "value": 55 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_pm02{instance=\"airgradient-one\"}", "legendFormat": "PM2.5" }]
    },
    {
      "title": "CO₂",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 1500 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_rco2{instance=\"airgradient-one\"}", "legendFormat": "CO₂" }]
    },
    {
      "title": "Temperature",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 18 },
              { "color": "orange", "value": 28 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_atmp{instance=\"airgradient-one\"}", "legendFormat": "Temp" }]
    },
    {
      "title": "Humidity",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 30 },
              { "color": "orange", "value": 60 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_rhum{instance=\"airgradient-one\"}", "legendFormat": "Humidity" }]
    },
    {
      "title": "PM1.0",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "µg/m³" } },
      "targets": [{ "expr": "airgradient_pm01{instance=\"airgradient-one\"}", "legendFormat": "PM1.0" }]
    },
    {
      "title": "PM10",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "µg/m³" } },
      "targets": [{ "expr": "airgradient_pm10{instance=\"airgradient-one\"}", "legendFormat": "PM10" }]
    },
    {
      "title": "VOC Index",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 250 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_tvoc_index{instance=\"airgradient-one\"}", "legendFormat": "VOC" }]
    },
    {
      "title": "NOx Index",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 150 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_nox_index{instance=\"airgradient-one\"}", "legendFormat": "NOx" }]
    },
    {
      "title": "WiFi Signal",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -70 },
              { "color": "green", "value": -50 }
            ]
          }
        }
      },
      "targets": [{ "expr": "airgradient_wifi{instance=\"airgradient-one\"}", "legendFormat": "WiFi" }]
    },
    {
      "title": "PM2.5 Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "µg/m³" } },
      "targets": [
        { "expr": "airgradient_pm01{instance=\"airgradient-one\"}", "legendFormat": "PM1.0" },
        { "expr": "airgradient_pm02{instance=\"airgradient-one\"}", "legendFormat": "PM2.5" },
        { "expr": "airgradient_pm10{instance=\"airgradient-one\"}", "legendFormat": "PM10" }
      ]
    },
    {
      "title": "CO₂ Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ppm" } },
      "targets": [{ "expr": "airgradient_rco2{instance=\"airgradient-one\"}", "legendFormat": "CO₂" }]
    },
    {
      "title": "Temperature & Humidity Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Temp" },
            "properties": [{ "id": "unit", "value": "celsius" }]
          },
          {
            "matcher": { "id": "byName", "options": "Humidity" },
            "properties": [{ "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "targets": [
        { "expr": "airgradient_atmp{instance=\"airgradient-one\"}", "legendFormat": "Temp" },
        { "expr": "airgradient_rhum{instance=\"airgradient-one\"}", "legendFormat": "Humidity" }
      ]
    },
    {
      "title": "VOC & NOx Index Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "airgradient_tvoc_index{instance=\"airgradient-one\"}", "legendFormat": "VOC Index" },
        { "expr": "airgradient_nox_index{instance=\"airgradient-one\"}", "legendFormat": "NOx Index" }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "AirGradient Air Quality",
  "uid": "airgradient",
  "version": 1
}
